{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ipmhub.local/schemas/workspace-configuration.schema.json",
  "title": "IPM Hub Workspace Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri-reference"
    },
    "workingFolder": {
      "type": "string",
      "minLength": 1
    },
    "workspaceName": {
      "type": "string",
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9][\\w !@#$&+()[\\].<>-]{0,98}[\\w#()[\\]<>]$"
    },
    "associations": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-fA-F0-9]{16}$"
      },
      "uniqueItems": true
    },
    "defaultDownloadStrategy": {
      "type": "string",
      "enum": ["Single", "Multiple"]
    },
    "defaultNamePlacementRule": {
      "type": "string",
      "enum": ["IgnoreOwner", "Full"]
    },
    "packages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workspacePackage"
      }
    }
  },
  "required": ["packages"],
  "$defs": {
    "workspacePackage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z](?:[A-Za-z0-9-]{0,28})?[A-Za-z0-9](?:-sandbox)?\\/[A-Za-z](?:[A-Za-z0-9-]{1,62})?[A-Za-z0-9]$"
        },
        "version": {
          "type": "string",
          "pattern": "^(?!0\\.0\\.0(?:-.+)?$)(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)(?:-(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*)?$"
        },
        "versions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^(?!0\\.0\\.0(?:-.+)?$)(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)\\.(?:0|[1-9]\\d*)(?:-(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[A-Za-z-][0-9A-Za-z-]*))*)?$"
          }
        },
        "downloadStrategy": {
          "type": "string",
          "enum": ["Default", "Single", "Multiple"]
        },
        "namePlacementRule": {
          "type": "string",
          "enum": ["Default", "IgnoreOwner", "Full"]
        },
        "workingFolder": {
          "type": "string"
        }
      },
      "required": ["name"],
      "oneOf": [
        { "required": ["version"], "not": { "required": ["versions"] } },
        { "required": ["versions"], "not": { "required": ["version"] } }
      ]
    }
  }
}

